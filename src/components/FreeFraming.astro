---
import { DRYRUNS } from "../data/install";
---

<section id="free">
  <div class="wrap">
    <p class="eyebrow">Pricing</p>
    <h2 style="margin: 0 0 12px; font-size: clamp(1.5rem, 3vw, 2rem);">Free, unlimited, shareware-style</h2>
    <p class="lede">
      Budgetary is free to use without limits. Grab a free <code>bg_test_</code> key, add the MCP
      server, and start getting pre-flight estimates. No card, no metering games — when there's a
      paid tier it'll be for scale and team features, never for honest answers.
    </p>
    <div style="display: flex; gap: 12px; flex-wrap: wrap; margin-top: 24px;">
      <a class="btn btn-primary" href="/signup">Get a free key</a>
      <a class="btn btn-ghost" href={DRYRUNS}>See it live at dryruns.tools →</a>
    </div>
    <p class="note">
      A <code>bg_test_</code> key is ungated and free. <code>bg_live_</code> keys are issued per
      organization for production use.
    </p>
  </div>
</section>
